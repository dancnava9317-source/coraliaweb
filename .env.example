# ─────────────────────────────────────────
#  CORALIA BACKEND — Variables de entorno
#  Copia este archivo como .env y rellena tus valores reales
#  NUNCA subas .env a GitHub
# ─────────────────────────────────────────

# Puerto del servidor
PORT=3001

# Clave secreta para firmar los JWT (pon algo largo y aleatorio)
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_123

# Contraseña del panel de administración
ADMIN_PASSWORD=tu_contraseña_segura_aqui

# ── Cloudinary (almacenamiento de fotos) ──
# Regístrate gratis en cloudinary.com y copia estos datos
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Entorno ──
NODE_ENV=development
